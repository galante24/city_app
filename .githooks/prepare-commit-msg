#!/bin/sh
# Пустой текст коммита (без -m): auto: safe update <file> (+N files)
# $1 = файл сообщения, $2 = источник
set -eu

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 0
MSG_FILE="${1:-}"
COMMIT_USE="${2:-}"

case "$COMMIT_USE" in
  merge|squash|commit) exit 0 ;;
esac

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

if [ "$COMMIT_USE" = "message" ]; then
  exit 0
fi

if [ -n "$(awk '!/^#/ && $0!="" {print; exit}' "$MSG_FILE" 2>/dev/null || true)" ]; then
  exit 0
fi

NAMES_LIST="$(git diff --cached --name-only 2>/dev/null | head -n 50 || true)"
# shellcheck disable=SC2002,SC2016
NFILES=0
if [ -n "$NAMES_LIST" ]; then
  NFILES=$(printf '%s\n' "$NAMES_LIST" | sed '/^$/d' | grep -c . || true)
fi
if [ -z "$NFILES" ] || [ "$NFILES" -lt 0 ] 2>/dev/null; then
  NFILES=0
fi
TOP="$(printf '%s' "$NAMES_LIST" | head -n 1 | sed 's|.*/||')"

if [ -n "$TOP" ] && [ "$NFILES" -gt 0 ] 2>/dev/null; then
  {
    echo "auto: safe update $TOP (+${NFILES} files)"
    echo ""
    echo "Staged (stat):"
    git diff --cached --stat 2>/dev/null | head -n 25
  } > "${MSG_FILE}.new" && mv "${MSG_FILE}.new" "$MSG_FILE"
else
  echo "chore: update" > "${MSG_FILE}.new" && mv "${MSG_FILE}.new" "$MSG_FILE"
fi

exit 0
