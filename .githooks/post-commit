#!/bin/sh
# post-commit: git push ТОЛЬКО при AUTO_PUSH=1. Иначе — подсказка про deploy.
# Лог: builds/.githook_postcommit.log
set -eu

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

if [ -n "${CI:-}" ] || [ -n "${GITHUB_ACTIONS:-}" ]; then
  exit 0
fi

if [ "${GIT_HOOK_NO_PUSH:-0}" = "1" ] || [ "${GIT_HOOK_NO_PUSH:-}" = "true" ]; then
  echo "post-commit: GIT_HOOK_NO_PUSH, push пропущен" >&2
  echo "post-commit: Run git push to deploy" >&2
  exit 0
fi

# Windows: cmd/PowerShell часто не передают env в sh-хук; githook.autoPush из release.ps1 — дубль AUTO_PUSH
GITHOOK_AP="$(git config --get githook.autoPush 2>/dev/null || true)"
PUSH_WANTED=0
if [ "$GITHOOK_AP" = "1" ] || [ "$GITHOOK_AP" = "true" ]; then
  PUSH_WANTED=1
fi
if [ "${AUTO_PUSH:-0}" = "1" ] || [ "${AUTO_PUSH:-}" = "true" ]; then
  PUSH_WANTED=1
fi
if [ "$PUSH_WANTED" != "1" ]; then
  echo "post-commit: push не выполнялся (по умолчанию). Run git push to deploy" >&2
  echo "post-commit: или: AUTO_PUSH=1 / tool/release.ps1 / release.cmd" >&2
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 0

BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
if [ "$BRANCH" = "HEAD" ]; then
  echo "post-commit: detached HEAD, push пропущен" >&2
  echo "post-commit: Run git push to deploy" >&2
  exit 0
fi

if ! git remote get-url origin >/dev/null 2>&1; then
  echo "post-commit: нет remote origin" >&2
  echo "post-commit: Run git push to deploy" >&2
  exit 0
fi

LOGF="$REPO_ROOT/builds/.githook_postcommit.log"
mkdir -p "$REPO_ROOT/builds" 2>/dev/null || true
{
  echo "=== post-commit AUTO_PUSH=1 $BRANCH $(date 2>/dev/null || true) ==="
} >>"$LOGF" 2>/dev/null || true

if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  if git push >>"$LOGF" 2>&1; then
    echo "post-commit: git push выполнен" >&2
  else
    echo "post-commit: git push не удался (см. $LOGF)" >&2
    exit 0
  fi
else
  echo "post-commit: ветка $BRANCH без upstream, выполните: git push -u origin $BRANCH" | tee -a "$LOGF" >&2
  echo "post-commit: Run git push to deploy" >&2
  exit 0
fi

exit 0
