#!/bin/sh
# prepare-commit-msg: если сообщение пустое — сгенерировать краткое по git diff (кэш).
# $1 = путь к файлу сообщения, $2 = источник (message|template|merge|squash|commit)
set -eu

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 0
MSG_FILE="${1:-}"
COMMIT_USE="${2:-}"

# merge / squash / amend: не затираем
case "$COMMIT_USE" in
  merge|squash|commit) exit 0 ;;
esac

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

# Пользователь явно дал -m: не перетираем
if [ "$COMMIT_USE" = "message" ]; then
  exit 0
fi

# Первый непустой не-комментарий
if [ -n "$(awk '!/^#/ && $0!="" {print; exit}' "$MSG_FILE" 2>/dev/null || true)" ]; then
  exit 0
fi

# Статистика по staged (в pre-commit мы уже подмешали pubspec)
if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

STAT="$(git diff --cached --stat 2>/dev/null | head -n 20 || true)"
NAMES="$(git diff --cached --name-only 2>/dev/null | head -n 8 | tr '\n' ',' | sed 's/,$//' || true)"
TOP="$(git diff --cached --name-only 2>/dev/null | head -n 1 | sed 's|.*/||' || true)"

# Короткое инфо о типе
PREF="chore"
if echo "$NAMES" | grep -E '\.(dart)$' >/dev/null 2>&1; then
  PREF="chore"
fi
# если только конфиг/скрипты
if [ -n "$TOP" ] && [ -n "$NAMES" ]; then
  NFILES="$(printf '%s\n' "$NAMES" | tr ',' '\n' | grep -c . 2>/dev/null || echo 0)"
  FIRST_LINE="auto: safe update ${TOP} (+${NFILES} files)"
  # shellcheck disable=SC2002
  {
    echo "$FIRST_LINE"
    echo ""
    echo "Staged (stat):"
    echo "$STAT"
  } > "${MSG_FILE}.new" && mv "${MSG_FILE}.new" "$MSG_FILE"
else
  echo "chore: update" > "${MSG_FILE}.new" && mv "${MSG_FILE}.new" "$MSG_FILE"
fi

exit 0
